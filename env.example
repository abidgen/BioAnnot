ANTHROPIC_API_KEY=sk-ant-...
NCBI_EMAIL=your.email@nih.gov
NCBI_API_KEY=
CONFIDENCE_THRESHOLD=0.65
LOG_LEVEL=INFO
DISEASE_CONTEXT=cancer          # or: fibrosis, neurodegeneration, cardiovascular, immunology
DISEASE_TERMS=cancer,tumor,carcinoma,sarcoma,lymphoma,leukemia
EXTRACTION_MODEL=claude-opus-4-8
MERGE_MODEL=claude-sonnet-4-6
# CellxGene Census (single-cell expression grounding for cellular_states)
ENABLE_CELLXGENE=true
CENSUS_VERSION=2024-07-01
CENSUS_TISSUE=lung
CENSUS_MIN_CELLS=50
CENSUS_CACHE_DIR=refs/census_cache/
# Fuzzy pathway canonicalization (src/merger.py) + synonym builder
FUZZY_THRESHOLD=85
AUTO_UPDATE_SYNONYMS=false
SYNONYM_MODEL=claude-sonnet-4-6
SYNONYM_CANDIDATES=10
# Two-layer on-disk resume cache (raw extraction layer + final enriched layer)
ENABLE_CACHE=true       # set false to disable both cache layers
CACHE_DIR=outputs/cache/   # holds raw/ (extractions) and final/ (enriched records)
FORCE_RERUN=false       # true: bypass BOTH layers, recompute the whole chain
FORCE_REMERGE=false     # true: bypass final layer only, replay merge+enrich from
                        #       the raw cache (zero API cost; use after editing
                        #       refs/pathway_synonyms.json or reactome_pathways.txt)
PRUNE_CACHE=true        # after a run, delete cache files whose keys no longer
                        #       match the current config (skipped under FORCE_RERUN)
