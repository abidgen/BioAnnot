ANTHROPIC_API_KEY=sk-ant-...
NCBI_EMAIL=your.email@nih.gov
NCBI_API_KEY=
CONFIDENCE_THRESHOLD=0.65
LOG_LEVEL=INFO
DISEASE_CONTEXT=cancer          # or: fibrosis, neurodegeneration, cardiovascular, immunology
DISEASE_TERMS=cancer,tumor,carcinoma,sarcoma,lymphoma,leukemia
EXTRACTION_MODEL=claude-opus-4-8
MERGE_MODEL=claude-sonnet-4-6
# CellxGene Census (single-cell expression grounding for cellular_states)
ENABLE_CELLXGENE=true
CENSUS_VERSION=2024-07-01
CENSUS_TISSUE=lung
CENSUS_MIN_CELLS=50
CENSUS_CACHE_DIR=refs/census_cache/
# Fuzzy pathway canonicalization (src/merger.py) + synonym builder
FUZZY_THRESHOLD=85
AUTO_UPDATE_SYNONYMS=false
SYNONYM_MODEL=claude-sonnet-4-6
SYNONYM_CANDIDATES=10
